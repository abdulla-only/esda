# ============================================================================
# esda environment template.
#
# Copy to:
#   .env.local        -> host (make *-local). DATABASE_URL points at localhost.
#   .env.development  -> docker (make dev).   DATABASE_URL points at the `db` host.
#
# NEVER commit real secrets. These are all placeholders.
# ============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# --- Database ---
# Postgres credentials used by the `db` service and to build DATABASE_URL.
POSTGRES_USER=esda
POSTGRES_PASSWORD=esda
POSTGRES_DB=esda
# Host-published port. 5433 avoids clashing with a local Postgres on 5432.
POSTGRES_PORT=5433
# Host (.env.local):        postgres://esda:esda@localhost:5433/esda
# Docker (.env.development): postgres://esda:esda@db:5432/esda  (compose network)
DATABASE_URL=postgres://esda:esda@db:5432/esda

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Telegram ---
# BotFather token. Required for /api/auth/telegram and the bot.
BOT_TOKEN=123456:replace-with-real-bot-token
# Public HTTPS URL of the deployed Mini App (the web/ build). Used by the bot's
# web_app button. For local testing use an https tunnel (e.g. ngrok).
MINI_APP_URL=https://your-mini-app.example.com
# How long (seconds) Telegram initData is accepted after auth_date.
TELEGRAM_AUTH_TTL=86400
# How the bot reaches the API (compose network uses the service name).
BOT_API_URL=http://api:8000

# --- JWT (djangorestframework-simplejwt) ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- CORS ---
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- SRS ---
DAILY_NEW_LIMIT=20

# --- Web (Vite, build-time; must be prefixed VITE_) ---
VITE_API_URL=http://localhost:8000

# --- API container convenience ---
# Set to 1 to auto-run `manage.py seed` on api container startup.
AUTO_SEED=0
API_PORT=8000
WEB_PORT=5173
